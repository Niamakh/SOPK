{
  "name": "healthcorner-sopk",
  "version": "1.0.0",
  "private": true,
  "description": "Build assets (Tailwind CSS) for the Health Corner SOPK static site.",
  "scripts": {
    "build:css:sexualite": "tailwindcss -i src/tailwind-input.css -o css/article-sopk-sexualite.css --minify",
    "watch:css:sexualite": "tailwindcss -i src/tailwind-input.css -o css/article-sopk-sexualite.css --watch",
    "build:css:keto": "tailwindcss -c tailwind.config.keto.js -i src/tailwind-input.css -o css/article-sopk-keto.css --minify",
    "watch:css:keto": "tailwindcss -c tailwind.config.keto.js -i src/tailwind-input.css -o css/article-sopk-keto.css --watch",
    "build:css:complements": "tailwindcss -c tailwind.config.complements.js -i src/tailwind-input.css -o css/article-sopk-complements.css --minify",
    "watch:css:complements": "tailwindcss -c tailwind.config.complements.js -i src/tailwind-input.css -o css/article-sopk-complements.css --watch",
    "build:css:nidation": "tailwindcss -c tailwind.config.nidation.js -i src/tailwind-input.css -o css/nidation-combien-de-temps-apres-rapport.css --minify",
    "watch:css:nidation": "tailwindcss -c tailwind.config.nidation.js -i src/tailwind-input.css -o css/nidation-combien-de-temps-apres-rapport.css --watch",
    "build:css:saignement-nidation": "tailwindcss -c tailwind.config.saignement-nidation.js -i src/tailwind-input.css -o css/saignement-nidation-couleur-duree.css --minify",
