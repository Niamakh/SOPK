    "build:css:disque-grossesse": "tailwindcss -c tailwind.config.disque-grossesse.js -i src/tailwind-input.css -o css/disque-roue-grossesse-calcul-terme.css --minify",
    "watch:css:disque-grossesse": "tailwindcss -c tailwind.config.disque-grossesse.js -i src/tailwind-input.css -o css/disque-roue-grossesse-calcul-terme.css --watch",
    "build:css:journal-grossesse": "tailwindcss -c tailwind.config.journal-grossesse.js -i src/tailwind-input.css -o css/journal-grossesse-a-imprimer-gratuit.css --minify",
    "watch:css:journal-grossesse": "tailwindcss -c tailwind.config.journal-grossesse.js -i src/tailwind-input.css -o css/journal-grossesse-a-imprimer-gratuit.css --watch",
